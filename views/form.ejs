<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= item && item.ticketId ? 'Sửa vé' : 'Thêm vé mới' %></title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 32px 16px; }

    .card {
      max-width: 560px;
      margin: 0 auto;
      background: #fff;
      border-radius: 10px;
      border-top: 5px solid #e5e7eb;
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      padding: 28px;
    }

    .card h2 { margin: 0 0 20px; color: #15803d; font-size: 20px; }

    .err-box { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; border-radius: 6px; padding: 10px 14px; margin-bottom: 16px; font-size: 14px; }

    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .field { display: flex; flex-direction: column; margin-bottom: 14px; }
    .field label { font-size: 13px; font-weight: 700; color: #374151; margin-bottom: 5px; }
    .field .err { color: #dc2626; font-size: 12px; font-weight: 400; margin-left: 4px; }
    .field input,
    .field select {
      padding: 8px 10px;
      border: 1.5px solid #e5e7eb;
      border-radius: 6px;
      font-size: 14px;
      outline: none;
      transition: border-color .2s;
    }
    .field input:focus,
    .field select:focus { border-color: #6b7280; }
    .field input.has-err { border-color: #f87171; }

    .preview { max-width: 100%; border-radius: 6px; margin-top: 8px; border: 1px solid #e5e7eb; }

    .actions { display: flex; gap: 10px; margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7eb; }
    .btn-save {
      flex: 1;
      background: #16a34a;
      color: #fff;
      border: none;
      padding: 9px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }
    .btn-save:hover { background: #15803d; }
    .btn-back {
      background: #f3f4f6;
      color: #374151;
      text-decoration: none;
      padding: 9px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
    }
    .btn-back:hover { background: #e5e7eb; }

    @media (max-width: 480px) { .row2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <div class="card">
    <h2><%= item && item.ticketId ? 'Sửa vé' : 'Thêm vé mới' %></h2>

    <% const errs = typeof errors !== 'undefined' ? errors : {}; %>
    <% if (errs.general) { %>
      <div class="err-box"><%= errs.general %></div>
    <% } %>

    <form method="POST" enctype="multipart/form-data">

      <div class="row2">
        <div class="field">
          <label>Tên sự kiện <% if (errs.eventName) { %><span class="err">- <%= errs.eventName %></span><% } %></label>
          <input name="eventName" placeholder="Tên sự kiện" value="<%= (item && item.eventName) || '' %>" required
            class="<%= errs.eventName ? 'has-err' : '' %>" />
        </div>
        <div class="field">
          <label>Người giữ vé <% if (errs.holderName) { %><span class="err">- <%= errs.holderName %></span><% } %></label>
          <input name="holderName" placeholder="Họ và tên" value="<%= (item && item.holderName) || '' %>" required
            class="<%= errs.holderName ? 'has-err' : '' %>" />
        </div>
      </div>

      <div class="row2">
        <div class="field">
          <label>Số lượng <% if (errs.quantity) { %><span class="err">- <%= errs.quantity %></span><% } %></label>
          <input type="number" name="quantity" placeholder="1" value="<%= (item && item.quantity) || '' %>" required min="1"
            class="<%= errs.quantity ? 'has-err' : '' %>" />
        </div>
        <div class="field">
          <label>Giá mỗi vé (₫) <% if (errs.pricePerTicket) { %><span class="err">- <%= errs.pricePerTicket %></span><% } %></label>
          <input type="number" name="pricePerTicket" placeholder="0" value="<%= (item && item.pricePerTicket) || '' %>" required min="0"
            class="<%= errs.pricePerTicket ? 'has-err' : '' %>" />
        </div>
      </div>

      <div class="row2">
        <div class="field">
          <label>Loại vé</label>
          <select name="category">
            <option value="Standard" <%=item && item.category==='Standard' ? 'selected':'' %>>Thường</option>
            <option value="VIP"      <%=item && item.category==='VIP'      ? 'selected':'' %>>VIP</option>
            <option value="VVIP"     <%=item && item.category==='VVIP'     ? 'selected':'' %>>VVIP</option>
          </select>
        </div>
        <div class="field">
          <label>Ngày sự kiện <% if (errs.eventDate) { %><span class="err">- <%= errs.eventDate %></span><% } %></label>
          <input type="date" name="eventDate" value="<%= (item && item.eventDate) || '' %>" required
            class="<%= errs.eventDate ? 'has-err' : '' %>" />
        </div>
      </div>

      <div class="field">
        <label>Trạng thái</label>
        <select name="status">
          <option value="Upcoming"  <%=item && item.status==='Upcoming'  ? 'selected':'' %>>Sắp diễn ra</option>
          <option value="Sold"      <%=item && item.status==='Sold'      ? 'selected':'' %>>Đã bán</option>
          <option value="Cancelled" <%=item && item.status==='Cancelled' ? 'selected':'' %>>Đã huỷ</option>
        </select>
      </div>

      <div class="field">
        <label>Ảnh vé</label>
        <input type="file" name="image" accept="image/*" />
        <% if (item && item.imageUrl) { %>
          <img src="<%= item.imageUrl %>" alt="preview" class="preview" />
        <% } %>
      </div>

      <div class="actions">
        <a href="/" class="btn-back">← Quay lại</a>
        <button type="submit" class="btn-save">
          <%= item && item.ticketId ? 'Cập nhật' : 'Tạo vé' %>
        </button>
      </div>

    </form>
  </div>

</body>
</html>
